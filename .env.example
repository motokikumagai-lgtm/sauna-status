# Chillnn 管理画面のログイン情報
# このファイルをコピーして .env というファイル名にリネームし、
# 実際の値を入力してください。
# .env は gitignore されているので、Gitにコミットされません。

CHILLNN_EMAIL=your_email@example.com
CHILLNN_PASSWORD=your_password_here

# Chillnn 管理画面のURL（変更不要）
CHILLNN_ADMIN_URL=https://admin.chillnn.com/192d3a509c089/management/reservation

# エラー通知先メールアドレス
NOTIFY_EMAIL=motokikumagai@gmail.com
