# Chillnn 管理画面のログイン情報
# このファイルをコピーして .env というファイル名にリネームし、
# 実際の値を入力してください。
# .env は gitignore されているので、Gitにコミットされません。

CHILLNN_EMAIL=your_email@example.com
CHILLNN_PASSWORD=your_password_here

# Chillnn 管理画面のURL（変更不要）
CHILLNN_ADMIN_URL=https://admin.chillnn.com/192d3a509c089/management/reservation

# エラー通知先メールアドレス
NOTIFY_EMAIL=motokikumagai@gmail.com

# --- LINE 新規予約通知 (Messaging API push) ---
# LINE Developers で Messaging API チャネルを作成して取得する
# https://developers.line.biz/console/
LINE_CHANNEL_ACCESS_TOKEN=your_long_lived_channel_access_token
# 送信先 userId（自分のuserId、またはグループ送信ならgroupId）
LINE_USER_ID=your_line_user_id
